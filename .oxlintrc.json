{
  "plugins": ["typescript", "react", "jsx-a11y"],
  "options": {
    "typeAware": true
  },
  "env": {
    "browser": true,
    "es2020": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src-tauri/target/**",
    "src-tauri/gen/schemas/**"
  ],
  "overrides": [
    {
      "files": ["vite.config.ts"],
      "env": {
        "node": true
      }
    }
  ]
}
