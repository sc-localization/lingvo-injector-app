{
  "name": "lingvo-injector",
  "version": "0.1.0",
  "description": "Star Citizen Localization Installer",
  "private": true,
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "dev:app": "npm run tauri dev --workspace=app",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:app\"",
    "build:app": "npm run tauri:build:release --workspace=app",
    "build:server": "echo 'Server does not require build'",
    "start:server": "npm start --workspace=server",
    "lint:app": "npm run lint --workspace=app",
    "lint:server": "npm run lint --workspace=server",
    "lint": "npm run lint:app && npm run lint:server",
    "format:app": "npm run format --workspace=app",
    "format:server": "npm run format --workspace=server",
    "format": "npm run format:app && npm run format:server",
    "install:all": "npm install && npm install --workspace=app && npm install --workspace=server"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sc-localization/lingvo-injector-app"
  },
  "keywords": [
    "star-citizen",
    "localization",
    "translation",
    "tauri",
    "desktop-app"
  ],
  "author": "mvoof",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
